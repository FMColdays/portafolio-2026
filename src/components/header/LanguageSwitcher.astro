---
import { languages } from '@i18n/ui'
import { getRelativeLocaleUrl } from 'astro:i18n'

const lang = Astro.currentLocale ?? 'es'
---

<div role='group' aria-label='Language selector' class='inline-flex items-center p-0.5 rounded-lg bg-base-content/8 font-mono'>
  {
    Object.entries(languages).map(([code, label]) => (
      <a
        href={getRelativeLocaleUrl(code, '/')}
        aria-label={label}
        aria-current={code === lang ? 'page' : undefined}
        class:list={[
          'px-2.5 py-1 text-xs font-bold tracking-widest rounded-md leading-none transition-all duration-200',
          code === lang ? 'bg-base-content text-base-100 shadow-sm' : 'text-base-content/35 hover:text-base-content/60',
        ]}
      >
        {code.toUpperCase()}
      </a>
    ))
  }
</div>
