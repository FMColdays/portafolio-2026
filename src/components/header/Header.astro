---
import LanguageSwitcher from '@components/header/LanguageSwitcher.astro'
import Navigation from '@components/header/Navigation.astro'
import NavigationMobile from '@components/header/NavigationMobile.astro'
import ThemeController from '@components/header/ThemeController.astro'
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'

const lang = (Astro.currentLocale ?? 'es') as keyof typeof ui
const t = useTranslations(lang)

const navigation = [
  { label: t('nav.experience'), href: t('nav.experience.href') },
  { label: t('nav.projects'), href: t('nav.projects.href') },
  { label: t('nav.skills'), href: t('nav.skills.href') },
  { label: t('nav.about'), href: t('nav.about.href') },
]
---

<header class='sticky top-0 z-50 w-full pointer-events-none'>
  <div class='max-w-2xl mx-auto px-4 py-3'>
    <div id='nav-pill' class='pointer-events-auto flex items-center justify-between px-5 py-3'>
      <a href='/' class='flex items-center font-mono text-base font-bold tracking-tight select-none'>
        <span class='text-primary'>&lt;</span>
        <span class='mx-0.5'>Erick</span>
        <span class='text-primary'>/&gt;</span>
      </a>

      <Navigation navigation={navigation} />

      <div class='flex items-center gap-2'>
        <LanguageSwitcher />
        <ThemeController />
        <NavigationMobile navigation={navigation} />
      </div>
    </div>
  </div>
</header>

<style>
  @keyframes float-pill {
    from {
      border-radius: 0;
      background-color: transparent;
      backdrop-filter: blur(0px);
      -webkit-backdrop-filter: blur(0px);
      box-shadow:
        inset 0 0 0 1px transparent,
        0 0 0 0 transparent;
    }
    to {
      border-radius: 2rem;
      background-color: color-mix(in oklch, var(--color-base-200) 75%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow:
        inset 0 0 0 1px color-mix(in oklch, var(--color-base-content) 8%, transparent),
        0 8px 32px oklch(0% 0 0 / 0.12);
    }
  }

  #nav-pill {
    animation: float-pill linear both;
    animation-timeline: scroll();
    animation-range: 20px 100px;
  }
</style>
