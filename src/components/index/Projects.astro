---
import Link from '@components/shared/Link.astro'
import { techs, type TechKey } from '@data/tech'
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import ExternalLinkIcon from '@icons/ExternalLinkIcon.svg'
import GithubIcon from '@icons/GithubIcon.svg'
import CreditTrackerWeb from '@img/projects/credit-tracker-web.webp'
import FasolProject from '@img/projects/fasol-mobile.webp'
import FuelSoftwareControlProject from '@img/projects/fuel-software-control.webp'
import RitmoProject from '@img/projects/ritmo-son.webp'
import Tpms from '@img/projects/tpms.webp'
import FuelSoftwareControlWeb from '@img/projects/fuel-software-control-web.webp'
import WebUtilsImage from '@img/projects/web-utils.svg?url'

import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

const lang = (Astro.currentLocale ?? 'es') as keyof typeof ui
const t = useTranslations(lang)

interface Project {
  title: string
  description: string
  tags: TechKey[]
  image: ImageMetadata | null
  imageSrc?: string
  github?: string
  url?: string
}

const projects: Project[] = [
  {
    title: t('proj.ritmoson.title'),
    description: t('proj.ritmoson.desc'),
    tags: ['Astro', 'Preact', 'Sqlite', 'Prisma', 'Tanstack', 'Tailwind CSS'],
    image: RitmoProject,
    github: 'https://github.com/FMColdays/premios-ritmoson',
    url: 'https://premios-ritmoson.vercel.app',
  },
  {
    title: t('proj.fuelsoftware.title'),
    description: t('proj.fuelsoftware.desc'),
    tags: ['.Net', 'Tailwind CSS', 'Css', 'JavaScript', 'Sql Server'],
    image: FuelSoftwareControlProject,
    url: 'https://fuelsoftwarecontrol.com',
  },
  {
    title: t('proj.credimobile.title'),
    description: t('proj.credimobile.desc'),
    tags: ['React Native', 'Nativewind', 'MySQL', 'Tanstack'],
    image: FasolProject,
  },
  {
    title: t('proj.crediweb.title'),
    description: t('proj.crediweb.desc'),
    tags: ['.Net', 'Tailwind CSS', 'Sql Server', 'JavaScript', 'Css'],
    image: CreditTrackerWeb,
    url: 'credi-tracker.azurewebsites.net',
  },
  {
    title: t('proj.tpms.title'),
    description: t('proj.tpms.desc'),
    tags: ['Shopify', 'JavaScript', 'Css'],
    image: Tpms,
    url: 'https://tpms.ca',
  },
  {
    title: t('proj.fuelweb.title'),
    description: t('proj.fuelweb.desc'),
    tags: ['Astro', 'Tailwind CSS', 'Resend', 'Clerk', 'WordPress'],
    image: FuelSoftwareControlWeb,
    url: 'https://fuelsoftwarecontrol.ai',
  },
  {
    title: t('proj.webutils.title'),
    description: t('proj.webutils.desc'),
    tags: ['TypeScript'],
    image: null,
    imageSrc: WebUtilsImage,
    github: 'https://github.com/FMColdays/web-utils',
    url: 'https://www.npmjs.com/~fmcoldays',
  },
]

const sectionId = t('nav.projects.href').slice(1)
---

<section id={sectionId} class='py-24'>
  <div class='max-w-5xl mx-auto px-6'>
    <div class='flex items-center gap-4 mb-16 opacity-0' data-animate>
      <span class='font-mono text-[10px] text-primary tracking-[0.4em] uppercase'>[ 03 ]</span>
      <h2 class='text-3xl font-extrabold tracking-tight'>{t('projects.title')}</h2>
      <div class='flex-1 h-px bg-base-content/10'></div>
    </div>

    <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
      {
        projects.map((project, i) => (
          <article
            class={`group relative flex flex-col rounded-xl border border-base-content/8 bg-base-200/20 hover:border-primary/25 hover:bg-base-200/40 overflow-hidden transition-all duration-300 opacity-0${i >= 4 ? ' hidden' : ''}`}
            data-animate
            data-delay={i * 100}
            data-extra={i >= 4 ? '' : undefined}
          >
            <div class='relative w-full aspect-video overflow-hidden bg-base-content/3'>
              {project.image ? (
                <Image
                  class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                  src={project.image}
                  alt={project.title}
                />
              ) : project.imageSrc ? (
                <img
                  class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
                  src={project.imageSrc}
                  alt={project.title}
                />
              ) : (
                <div class='w-full h-full flex items-center justify-center bg-[radial-gradient(color-mix(in_oklch,var(--color-base-content)_6%,transparent)_1px,transparent_1px)] bg-size-[20px_20px]'>
                  <span class='font-mono font-black text-6xl text-base-content/6 select-none'>0{i + 1}</span>
                </div>
              )}
            </div>

            <div class='flex flex-col gap-3 p-5 flex-1'>
              <h3 class='font-bold text-base group-hover:text-primary transition-colors duration-200 leading-snug'>{project.title}</h3>
              <p class='text-sm text-base-content/50 leading-relaxed flex-1'>{project.description}</p>

              <div class='flex flex-wrap gap-1.5'>
                {project.tags.map(tag => {
                  const tech = techs[tag]
                  if (!tech)
                    return (
                      <span class='font-mono text-[10px] px-2 py-0.5 rounded-md bg-base-content/6 text-base-content/40 border border-base-content/8'>
                        {tag}
                      </span>
                    )
                  return (
                    <a
                      href={tech.href}
                      target='_blank'
                      rel='noopener noreferrer'
                      class='inline-flex items-center gap-1 font-mono text-[10px] px-2 py-0.5 rounded-md border transition-opacity duration-200 hover:opacity-70'
                      style={`background-color: ${tech.color}14; color: ${tech.color}; border-color: ${tech.color}30;`}
                    >
                      <tech.Icon class='w-3 h-3 shrink-0 fill-current' aria-hidden='true' />
                      {tag}
                    </a>
                  )
                })}
              </div>

              {(project.github || project.url) && (
                <div class='flex items-center gap-4 pt-3 border-t border-base-content/6'>
                  {project.github && (
                    <Link
                      className='inline-flex items-center gap-1.5 font-mono text-[11px] text-base-content/35 hover:text-base-content transition-colors duration-200'
                      href={project.github}
                      ariaLabel='Repositorio GitHub'
                      external
                    >
                      <GithubIcon class='w-3.5 h-3.5 shrink-0 fill-current' />
                      {t('projects.code')}
                    </Link>
                  )}
                  {project.url && (
                    <Link
                      className='inline-flex items-center gap-1.5 font-mono text-[11px] text-base-content/35 hover:text-primary transition-colors duration-200'
                      href={project.url}
                      ariaLabel='Ver sitio en vivo'
                      external
                    >
                      <ExternalLinkIcon class='w-3.5 h-3.5 shrink-0' />
                      {t('projects.demo')}
                    </Link>
                  )}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>

    {
      projects.length > 4 && (
        <div class='flex justify-center mt-8'>
          <button
            id='projects-toggle'
            data-label-more={t('projects.show_more')}
            data-label-less={t('projects.show_less')}
            class='inline-flex items-center gap-2 font-mono text-xs text-base-content/40 hover:text-base-content border border-base-content/10 hover:border-base-content/25 px-4 py-2 rounded-lg transition-all duration-200'
          >
            {t('projects.show_more')}
            <svg
              class='w-3.5 h-3.5 transition-transform duration-200'
              id='projects-chevron'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
            >
              <path d='M6 9l6 6 6-6' />
            </svg>
          </button>
        </div>
      )
    }
  </div>
</section>

<script>
  function initProjectsToggle() {
    const btn = document.getElementById('projects-toggle')
    if (!btn) return

    const extras = document.querySelectorAll<HTMLElement>('[data-extra]')
    let expanded = false

    btn.addEventListener('click', () => {
      expanded = !expanded
      const labelMore = (btn as HTMLElement).dataset.labelMore ?? ''
      const labelLess = (btn as HTMLElement).dataset.labelLess ?? ''

      extras.forEach(el => {
        if (expanded) {
          el.classList.remove('hidden')
          el.style.animationDelay = '0ms'
          el.classList.remove('opacity-0')
          el.classList.add('animate-fade-in-up')
        } else {
          el.classList.add('hidden')
          el.classList.remove('animate-fade-in-up')
          el.classList.add('opacity-0')
        }
      })

      const span = btn.childNodes[0] as Text
      span.textContent = expanded ? labelLess : labelMore

      const chevron = document.getElementById('projects-chevron')
      chevron?.classList.toggle('rotate-180', expanded)
    })
  }

  document.addEventListener('astro:page-load', initProjectsToggle)
</script>
