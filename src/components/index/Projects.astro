---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import ExternalLinkIcon from '@icons/ExternalLinkIcon.svg'
import GithubIcon       from '@icons/GithubIcon.svg'
import AstroIcon        from '@icons/AstroIcon.svg'
import DockerIcon       from '@icons/DockerIcon.svg'
import JavaIcon         from '@icons/JavaIcon.svg'
import MySQLIcon        from '@icons/MySQLIcon.svg'
import NodeIcon         from '@icons/NodeIcon.svg'
import PostgreSQLIcon   from '@icons/PostgreSQLIcon.svg'
import ReactIcon        from '@icons/ReactIcon.svg'
import ShopifyIcon      from '@icons/ShopifyIcon.svg'
import SpringBootIcon   from '@icons/SpringBootIcon.svg'
import TailwindIcon     from '@icons/TailwindIcon.svg'

const lang = (Astro.currentLocale ?? 'es') as keyof typeof ui
const t = useTranslations(lang)

interface Project {
  title:       string
  description: string
  tags:        string[]
  image:       ImageMetadata | null
  github:      string | null
  url:         string | null
  featured:    boolean
}

const techData: Record<string, { color: string; Icon: any }> = {
  'Node.js':      { color: '#339933', Icon: NodeIcon       },
  'React':        { color: '#61DAFB', Icon: ReactIcon      },
  'PostgreSQL':   { color: '#4169E1', Icon: PostgreSQLIcon },
  'Docker':       { color: '#2496ED', Icon: DockerIcon     },
  'Astro':        { color: '#FF5D01', Icon: AstroIcon      },
  'Tailwind CSS': { color: '#06B6D4', Icon: TailwindIcon   },
  'Shopify':      { color: '#7AB55C', Icon: ShopifyIcon    },
  'Java':         { color: '#ED8B00', Icon: JavaIcon       },
  'Spring Boot':  { color: '#6DB33F', Icon: SpringBootIcon },
  'MySQL':        { color: '#4479A1', Icon: MySQLIcon      },
}

const projects: Project[] = lang === 'es'
  ? [
      {
        title:       'Panel de Gestión Industrial',
        description: 'Dashboard en tiempo real para seguimiento de proyectos industriales, control de activos y reportes operativos. Incluye autenticación por roles y alertas configurables.',
        tags:        ['Node.js', 'React', 'PostgreSQL', 'Docker'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         null,
        featured:    true,
      },
      {
        title:       'Tienda E-commerce',
        description: 'Tienda en línea personalizada con catálogo dinámico, carrito y pasarela de pagos integrada. Optimizada para SEO y con puntuación Lighthouse > 95.',
        tags:        ['Astro', 'Tailwind CSS', 'Shopify'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         null,
        featured:    false,
      },
      {
        title:       'API REST Financiera',
        description: 'Backend para plataforma de gestión financiera con endpoints documentados en OpenAPI. Migración de sistema legacy con cobertura de pruebas unitarias > 80%.',
        tags:        ['Java', 'Spring Boot', 'MySQL'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         null,
        featured:    false,
      },
      {
        title:       'Portafolio Personal',
        description: 'Este sitio. Diseñado y desarrollado desde cero con Astro, i18n nativo, tema dark/light persistente y animaciones scroll-driven.',
        tags:        ['Astro', 'Tailwind CSS'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         'https://erickgp.dev',
        featured:    false,
      },
    ]
  : [
      {
        title:       'Industrial Management Dashboard',
        description: 'Real-time dashboard for industrial project tracking, asset control and operational reports. Includes role-based auth and configurable alerts.',
        tags:        ['Node.js', 'React', 'PostgreSQL', 'Docker'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         null,
        featured:    true,
      },
      {
        title:       'E-commerce Store',
        description: 'Custom online store with dynamic catalog, cart and integrated payment gateway. SEO-optimized with Lighthouse score > 95.',
        tags:        ['Astro', 'Tailwind CSS', 'Shopify'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         null,
        featured:    false,
      },
      {
        title:       'Financial REST API',
        description: 'Backend for a financial management platform with OpenAPI-documented endpoints. Legacy system migration with unit test coverage > 80%.',
        tags:        ['Java', 'Spring Boot', 'MySQL'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         null,
        featured:    false,
      },
      {
        title:       'Personal Portfolio',
        description: 'This site. Designed and built from scratch with Astro, native i18n, persistent dark/light theme and scroll-driven animations.',
        tags:        ['Astro', 'Tailwind CSS'],
        image:       null,
        github:      'https://github.com/FMColdays',
        url:         'https://erickgp.dev',
        featured:    false,
      },
    ]

const sectionId = t('nav.projects.href').slice(1)
---

<section id={sectionId} class='py-24'>
  <div class='max-w-5xl mx-auto px-6'>

    <div class='flex items-center gap-4 mb-16 opacity-0' data-animate>
      <span class='font-mono text-[10px] text-primary tracking-[0.4em] uppercase'>[ 03 ]</span>
      <h2 class='text-3xl font-extrabold tracking-tight'>{t('projects.title')}</h2>
      <div class='flex-1 h-px bg-base-content/10' />
    </div>

    <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
      {projects.map((project, i) => (
        <article
          class='group relative flex flex-col rounded-xl border border-base-content/8 bg-base-200/20 hover:border-primary/25 hover:bg-base-200/40 overflow-hidden transition-all duration-300 opacity-0'
          data-animate
          data-delay={i * 100}
        >
          <div class='relative w-full aspect-video overflow-hidden bg-base-content/3'>
            {project.image ? (
              <Image
                src={project.image}
                alt={project.title}
                class='w-full h-full object-cover transition-transform duration-500 group-hover:scale-105'
              />
            ) : (
              <div class='w-full h-full flex items-center justify-center bg-[radial-gradient(color-mix(in_oklch,var(--color-base-content)_6%,transparent)_1px,transparent_1px)] bg-size-[20px_20px]'>
                <span class='font-mono font-black text-6xl text-base-content/6 select-none'>0{i + 1}</span>
              </div>
            )}
            {project.featured && (
              <span class='absolute top-3 right-3 font-mono text-[9px] tracking-widest px-2 py-0.5 rounded-full bg-primary/10 border border-primary/30 text-primary/80 backdrop-blur-sm uppercase'>
                {t('projects.featured')}
              </span>
            )}
          </div>

          <div class='flex flex-col gap-3 p-5 flex-1'>
            <h3 class='font-bold text-base group-hover:text-primary transition-colors duration-200 leading-snug'>
              {project.title}
            </h3>
            <p class='text-sm text-base-content/50 leading-relaxed flex-1'>
              {project.description}
            </p>

            <div class='flex flex-wrap gap-1.5'>
              {project.tags.map(tag => {
                const tech = techData[tag]
                if (!tech) return (
                  <span class='font-mono text-[10px] px-2 py-0.5 rounded-md bg-base-content/6 text-base-content/40 border border-base-content/8'>
                    {tag}
                  </span>
                )
                return (
                  <span
                    class='inline-flex items-center gap-1 font-mono text-[10px] px-2 py-0.5 rounded-md border'
                    style={`background-color: ${tech.color}14; color: ${tech.color}; border-color: ${tech.color}30;`}
                  >
                    <tech.Icon class='w-3 h-3 shrink-0 fill-current' aria-hidden='true' />
                    {tag}
                  </span>
                )
              })}
            </div>

            {(project.github || project.url) && (
              <div class='flex items-center gap-4 pt-3 border-t border-base-content/6'>
                {project.github && (
                  <a
                    href={project.github}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='inline-flex items-center gap-1.5 font-mono text-[11px] text-base-content/35 hover:text-base-content transition-colors duration-200'
                    aria-label='Repositorio GitHub'
                  >
                    <GithubIcon class='w-3.5 h-3.5 shrink-0 fill-current' />
                    {t('projects.code')}
                  </a>
                )}
                {project.url && (
                  <a
                    href={project.url}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='inline-flex items-center gap-1.5 font-mono text-[11px] text-base-content/35 hover:text-primary transition-colors duration-200'
                    aria-label='Ver sitio en vivo'
                  >
                    <ExternalLinkIcon class='w-3.5 h-3.5 shrink-0' />
                    {t('projects.demo')}
                  </a>
                )}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
