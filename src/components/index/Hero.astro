---
import Link from '@components/shared/Link.astro'
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import GithubIcon   from '@icons/GithubIcon.svg'
import LinkedinIcon from '@icons/LinkedinIcon.svg'
import MailIcon     from '@icons/MailIcon.svg'
import MiImagen     from '@img/mi-imagen.webp'
import { Image } from 'astro:assets'

const lang = (Astro.currentLocale ?? 'es') as keyof typeof ui
const t = useTranslations(lang)

const socials = [
  { href: 'https://www.linkedin.com/in/erickgp51/', label: 'LinkedIn', ariLabel: 'LinkedIn',      Icon: LinkedinIcon, external: true  },
  { href: 'https://github.com/FMColdays',           label: 'GitHub',   ariLabel: 'GitHub',        Icon: GithubIcon,   external: true  },
  { href: 'mailto:erickgp51@gmail.com',             label: 'Email',    ariLabel: 'Enviar correo', Icon: MailIcon,     external: false },
]

---

<section class='relative min-h-screen flex flex-col justify-center overflow-hidden'>

  <!-- dot grid -->
  <div class='pointer-events-none absolute inset-0
    bg-[radial-gradient(color-mix(in_oklch,var(--color-base-content)_9%,transparent)_1px,transparent_1px)]
    bg-size-[28px_28px]' />

  <!-- radial fade masking center of dot grid -->
  <div class='pointer-events-none absolute inset-0
    bg-[radial-gradient(ellipse_65%_65%_at_50%_50%,transparent_20%,var(--color-base-100)_75%)]' />

  <!-- center content -->
  <div class='relative z-10 flex flex-col items-center text-center gap-5 px-6 py-20'>

    <!-- tag -->
    <p class='font-mono text-[9px] text-primary/50 tracking-[0.45em] uppercase animate-fade-in-up animate-delay-100'>
      {t('hero.tag')}
    </p>

    <!-- photo with tilted frame + corner brackets -->
    <div class='relative my-1 animate-fade-in-up animate-delay-200'>
      <!-- glow -->
      <div class='absolute inset-0 bg-primary/15 blur-3xl scale-[1.6]' />
      <!-- tilted frame -->
      <div class='relative w-36 h-36 sm:w-44 sm:h-44 rotate-3 overflow-hidden rounded-2xl
                  ring-1 ring-primary/20 ring-offset-[5px] ring-offset-base-100
                  shadow-2xl shadow-black/30'>
        <Image
          src={MiImagen}
          alt='Erick González'
          class='w-full h-full object-cover object-top'
        />
      </div>
      <!-- bracket marks -->
      <span class='absolute -top-2.5 -left-2.5 w-5 h-5 border-t-2 border-l-2 border-primary/45 rounded-tl'></span>
      <span class='absolute -top-2.5 -right-2.5 w-5 h-5 border-t-2 border-r-2 border-primary/45 rounded-tr'></span>
      <span class='absolute -bottom-2.5 -left-2.5 w-5 h-5 border-b-2 border-l-2 border-primary/45 rounded-bl'></span>
      <span class='absolute -bottom-2.5 -right-2.5 w-5 h-5 border-b-2 border-r-2 border-primary/45 rounded-br'></span>
    </div>

    <!-- name -->
    <h1 class='font-black text-[clamp(2.75rem,9vw,5.5rem)] leading-[0.88] tracking-tighter animate-fade-in-up animate-delay-300'>
      {t('hero.greeting')}
    </h1>

    <!-- role strip -->
    <div class='flex items-center gap-4 w-full max-w-xs sm:max-w-sm animate-fade-in-up animate-delay-400'>
      <div class='flex-1 h-px bg-base-content/10' />
      <span class='font-mono text-[9px] text-primary/60 tracking-[0.45em] uppercase shrink-0'>
        {t('hero.role')}
      </span>
      <div class='flex-1 h-px bg-base-content/10' />
    </div>

    <!-- description -->
    <p class='text-base-content/45 text-[13px] leading-relaxed max-w-[22rem] animate-fade-in-up animate-delay-500'>
      {t('hero.description')}
    </p>

    <!-- socials -->
    <div class='flex items-center gap-1' style='animation: fadeInUp .5s ease both; animation-delay: 600ms'>
      {socials.map(({ href, label, ariLabel, Icon, external }) => (
        <Link
          className='flex items-center gap-2 px-3 py-2 rounded-lg text-base-content/35 hover:text-base-content hover:bg-base-content/6 transition-all duration-200 font-mono text-xs'
          href={href}
          ariLabel={ariLabel}
          external={external}
        >
          <Icon class='w-4 h-4 shrink-0 fill-current' />
          <span>{label}</span>
        </Link>
      ))}
    </div>

  </div>


</section>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
