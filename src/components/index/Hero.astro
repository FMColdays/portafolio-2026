---
import Link from '@components/shared/Link.astro'
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import GithubIcon from '@icons/GithubIcon.svg'
import LinkedinIcon from '@icons/LinkedinIcon.svg'
import MailIcon from '@icons/MailIcon.svg'
import MiImagen from '@img/mi-imagen.webp'
import { Image } from 'astro:assets'

const lang = Astro.currentLocale ?? 'es'
const t = useTranslations(lang)

const socials = [
  {
    href: 'https://www.linkedin.com/in/erickgp51/',
    label: 'LinkedIn',
    ariLabel: 'LinkedIn',
    Icon: LinkedinIcon,
    external: true,
  },
  {
    href: 'https://github.com/FMColdays',
    label: 'GitHub',
    ariLabel: 'GitHub',
    Icon: GithubIcon,
    external: true,
  },
  {
    href: 'mailto:erickgp51@gmail.com',
    label: 'Email',
    ariLabel: 'Enviar correo',
    Icon: MailIcon,
    external: false,
  },
]
---

<section
  class='min-h-screen flex items-center overflow-hidden bg-[radial-gradient(circle,color-mix(in_oklch,var(--color-base-content)_5%,transparent)_1px,transparent_1px)] bg-size-[28px_28px]'
>
  <div class='w-full max-w-5xl mx-auto px-6'>
    <div class='relative flex-1 flex flex-col md:flex-row md:items-center gap-10 md:gap-0 py-10'>
      <div class='flex justify-center md:absolute md:right-0 md:top-1/2 md:-translate-y-1/2 animate-fade-in-up animate-delay-150' >
        <div class='relative'>
          <div class='absolute inset-0 translate-x-3 translate-y-3 rounded-2xl border border-primary/35'></div>
          <div
            class='relative w-40 h-52 sm:w-48 sm:h-64 md:w-60 md:h-80 rounded-2xl overflow-hidden md:-rotate-2 shadow-2xl shadow-black/40'
          >
            <Image  class='w-full h-full object-cover object-top'  src={MiImagen} alt='Erick González' />
            <div class='absolute inset-0 bg-linear-to-t from-black/25 to-transparent'></div>
          </div>
          <div
            class='absolute -bottom-4 -left-6 z-10 flex items-center gap-2 bg-primary text-primary-content font-mono text-[10px] tracking-wider px-3 py-1.5 rounded-full shadow-lg shadow-primary/30'
          >
            <span class='w-1.5 h-1.5 rounded-full bg-primary-content animate-pulse shrink-0'></span>
            {t('hero.role')}
          </div>
        </div>
      </div>

      <div class='relative z-10 md:max-w-md animate-fade-in-up animate-delay-250'>
        <p class='font-mono text-xs text-primary/60 tracking-widest mb-5'>
          {t('hero.tag')}
        </p>
        <h1 class='text-4xl sm:text-5xl md:text-7xl font-extrabold leading-[1.05] tracking-tight mb-6'>
          {t('hero.greeting')}
        </h1>
        <p class='text-base-content/50 text-base leading-relaxed border-l-2 border-primary/30 pl-4'>
          {t('hero.description')}
        </p>
      </div>
    </div>

    <div class='flex items-center gap-1 animate-fade-in-up animate-delay-500'>
      {
        socials.map(({ href, label, ariLabel, Icon, external }) => (
          <Link
            className='flex items-center gap-2 px-3 py-2 rounded-lg text-base-content/35 hover:text-base-content hover:bg-base-content/6 transition-all duration-200 font-mono text-xs'
            href={href}
            ariLabel={ariLabel}
            external={external}
          >
            <Icon class='w-4 h-4 shrink-0' />
            <span class='hidden sm:inline'>{label}</span>
          </Link>
        ))
      }
    </div>
  </div>
</section>
