---
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import { techs, type TechKey } from '@data/tech'

const lang = (Astro.currentLocale ?? 'es') as keyof typeof ui
const t = useTranslations(lang)

interface Experience {
  company:     string
  role:        string
  period:      [string, string | null]
  description: string
  tags:        TechKey[]
}

const experiences: Experience[] = [
  {
    company:     'Gasmonsoft',
    role:        t('exp.gasmonsoft.role'),
    period:      [t('exp.gasmonsoft.from'), null],
    description: t('exp.gasmonsoft.desc'),
    tags:        ['.Net', 'Astro', 'Tailwind CSS', 'JavaScript', 'Sql Server'],
  },
  {
    company:     'Grupo Aguilera',
    role:        t('exp.aguilera.role'),
    period:      [t('exp.aguilera.from'), t('exp.aguilera.to')],
    description: t('exp.aguilera.desc'),
    tags:        ['React Native', 'Nativewind', '.Net', 'MySQL', 'Tanstack'],
  },
  {
    company:     'Freelance',
    role:        t('exp.freelance.role'),
    period:      [t('exp.freelance.from'), t('exp.freelance.to')],
    description: t('exp.freelance.desc'),
    tags:        ['Astro', 'Shopify', 'Tailwind CSS', 'JavaScript'],
  },
]

    const sectionId = t('nav.experience.href').slice(1)
---

<section id={sectionId} class='py-24'>
  <div class='max-w-5xl mx-auto px-6'>
    <div class='flex items-center gap-4 mb-16 opacity-0' data-animate>
      <span class='font-mono text-[10px] text-primary tracking-[0.4em] uppercase'>[ 02 ]</span>
      <h2 class='text-3xl font-extrabold tracking-tight'>{t('experience.title')}</h2>
      <div class='flex-1 h-px bg-base-content/10' />
    </div>

    <div class='relative'>
      <div class='absolute left-0 top-2 bottom-2 w-px bg-base-content/10 hidden md:block' />
      <div class='flex flex-col gap-12'>
        {experiences.map((exp, i) => (
          <div class='group md:pl-10 relative opacity-0' data-animate data-delay={i * 150}>

            <div class='hidden md:flex absolute -left-1.25 top-1.5 w-2.75 h-2.75 rounded-full border-2 border-primary bg-base-100 group-hover:bg-primary transition-colors duration-300' />

            <div class='flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3'>
              <div>
                <h3 class='font-bold text-lg leading-tight'>{exp.role}</h3>
                <p class='font-mono text-sm text-primary'>{exp.company}</p>
              </div>
              <span class='font-mono text-xs text-base-content/40 whitespace-nowrap pt-0.5'>
                {exp.period[0]} — {exp.period[1] ?? t('experience.present')}
              </span>
            </div>

            <p class='text-base-content/55 text-sm leading-relaxed mb-4 max-w-xl'>
              {exp.description}
            </p>

            <div class='flex flex-wrap gap-2'>
              {exp.tags.map(tag => {
                const tech = techs[tag]
                if (!tech) return (
                  <span class='font-mono text-[11px] px-2.5 py-1 rounded-md bg-base-content/6 text-base-content/50 border border-base-content/8'>
                    {tag}
                  </span>
                )
                return (
                  <a
                    href={tech.href}
                    target='_blank'
                    rel='noopener noreferrer'
                    class='inline-flex items-center gap-1.5 font-mono text-[11px] px-2.5 py-1 rounded-md border transition-all duration-200 hover:opacity-80'
                    style={`background-color: ${tech.color}18; color: ${tech.color}; border-color: ${tech.color}35;`}
                  >
                    <tech.Icon class='w-3.5 h-3.5 shrink-0 fill-current' aria-hidden='true' />
                    {tag}
                  </a>
                )
              })}
            </div>

          </div>
        ))}
      </div>
    </div>

  </div>
</section>
