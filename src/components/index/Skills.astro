---
import type { ui } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import { techs, type TechKey } from '@data/tech'

const lang = (Astro.currentLocale ?? 'es') as keyof typeof ui
const t = useTranslations(lang)

interface Category {
  key:    string
  skills: TechKey[]
}

const categories: Category[] = [
  { key: 'skills.cat.frontend',  skills: ['TypeScript', 'JavaScript', 'React', 'Preact', 'Astro', 'Tailwind CSS'] },
  { key: 'skills.cat.mobile',    skills: ['React Native', 'Nativewind'] },
  { key: 'skills.cat.backend',   skills: ['Node.js', '.Net', 'Java'] },
  { key: 'skills.cat.databases', skills: ['PostgreSQL', 'MySQL', 'Sqlite', 'Sql Server', 'Prisma'] },
  { key: 'skills.cat.devops',    skills: ['Docker', 'Git'] },
  { key: 'skills.cat.cms',       skills: ['Shopify', 'WordPress'] },
]

const sectionId = t('nav.skills.href').slice(1)
---

<section id={sectionId} class='py-24'>
  <div class='max-w-5xl mx-auto px-6'>

    <div class='flex items-center gap-4 mb-16 opacity-0' data-animate>
      <span class='font-mono text-[10px] text-primary tracking-[0.4em] uppercase'>[ 04 ]</span>
      <h2 class='text-3xl font-extrabold tracking-tight'>{t('skills.title')}</h2>
      <div class='flex-1 h-px bg-base-content/10' />
    </div>

    <div class='flex flex-col divide-y divide-base-content/6'>
      {categories.map((cat, i) => (
        <div
          class='grid grid-cols-1 sm:grid-cols-[180px_1fr] gap-3 sm:gap-6 py-6 first:pt-0 last:pb-0 opacity-0'
          data-animate
          data-delay={i * 100}
        >
          <span class='font-mono text-[10px] text-base-content/35 tracking-widest uppercase pt-1 shrink-0'>
            {t(cat.key as any)}
          </span>

          <div class='flex flex-wrap gap-2'>
            {cat.skills.map(key => {
              const skill = techs[key]
              if (!skill) return null
              return (
                <a
                  href={skill.href}
                  target='_blank'
                  rel='noopener noreferrer'
                  class='group/skill inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border transition-all duration-200 hover:scale-105 hover:opacity-80'
                  style={`background-color: ${skill.color}12; color: ${skill.color}; border-color: ${skill.color}28;`}
                >
                  <skill.Icon class='w-4 h-4 shrink-0 fill-current' aria-hidden='true' />
                  <span class='font-mono text-[11px] font-medium tracking-wide'>{skill.name}</span>
                </a>
              )
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
