{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@layouts/*": ["./src/layouts/*"],
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"],
      "@icons/*": ["./src/assets/icons/*"],
      "@img/*": ["./src/assets/img/*"],
      "@i18n/*": ["./src/i18n/*"],
      "@data/*": ["./src/data/*"]
    }
  }
}
